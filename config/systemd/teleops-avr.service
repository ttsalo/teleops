[Unit]
Description=Teleops AVR Interface (motor control + telemetry)
After=network.target dev-ttyUSB0.device
Requires=dev-ttyUSB0.device

[Service]
Type=simple
User=ttsalo
ExecStart=/usr/local/bin/teleops-avr.sh
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
